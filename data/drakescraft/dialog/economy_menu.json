{
  "type": "minecraft:notice",
  "title": {
    "text": "💰 Economía, Pagos y Subastas",
    "bold": true,
    "color": "gold",
    "type": "text"
  },
  "body": [
    {
      "type": "text",
      "text": "Administra tus monedas, compra, vende y revisa los más ricos:"
    }
  ],
  "inputs": [
    {
      "key": "price",
      "label": "Precio para Subastar Ítem en Mano (/ah sell):",
      "type": "minecraft:text"
    }
  ],
  "buttons": [
    {
      "label": {
        "text": "💵 Ver Mi Saldo Actual (/bal)",
        "type": "text"
      },
      "action": {
        "type": "minecraft:run_command",
        "command": "/bal"
      }
    },
    {
      "label": {
        "text": "🏆 Top Jugadores Más Ricos (/baltop)",
        "type": "text"
      },
      "action": {
        "type": "minecraft:run_command",
        "command": "/baltop"
      }
    },
    {
      "label": {
        "text": "⚖️ Abrir Casa de Subastas (/ah)",
        "type": "text"
      },
      "action": {
        "type": "minecraft:run_command",
        "command": "/ah"
      }
    },
    {
      "label": {
        "text": "🏷️ Vender Ítem en Mano (/ah sell)",
        "type": "text"
      },
      "action": {
        "type": "minecraft:dynamic/run_command",
        "template": "ah sell $(price)"
      }
    },
    {
      "label": {
        "text": "🛒 Tienda del Servidor (/tienda)",
        "type": "text"
      },
      "action": {
        "type": "minecraft:run_command",
        "command": "/tienda"
      }
    },
    {
      "label": {
        "text": "💳 Transferir Dinero a Jugador",
        "type": "text"
      },
      "action": {
        "type": "minecraft:change_page",
        "dialog": "drakescraft:pay_menu"
      }
    },
    {
      "label": {
        "text": "⬅ Volver al Menú Principal",
        "type": "text"
      },
      "action": {
        "type": "minecraft:change_page",
        "dialog": "drakescraft:main_menu"
      }
    }
  ]
}