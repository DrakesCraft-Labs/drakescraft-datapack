{
  "type": "minecraft:multi_action",
  "title": {
    "text": "Transferir Dinero",
    "bold": true,
    "color": "green"
  },
  "body": {
    "type": "minecraft:plain_message",
    "contents": {
      "text": "Ingresa el nombre del jugador y el monto a enviar:"
    }
  },
  "inputs": [
    {
      "type": "minecraft:text",
      "key": "player_name",
      "label": {
        "text": "Nombre del Jugador:"
      }
    },
    {
      "type": "minecraft:text",
      "key": "amount",
      "label": {
        "text": "Monto / Cantidad:"
      }
    }
  ],
  "actions": [
    {
      "label": {
        "text": "✔ Enviar Pago"
      },
      "action": {
        "type": "minecraft:dynamic/run_command",
        "template": "pay $(player_name) $(amount)"
      }
    },
    {
      "label": {
        "text": "⬅ Volver"
      },
      "action": {
        "type": "minecraft:show_dialog",
        "dialog": "drakescraft:main_menu"
      }
    }
  ]
}