{
  "title": {
    "text": "Transferir Dinero",
    "bold": true,
    "color": "green"
  },
  "body": {
    "text": "Ingresa el nombre del jugador y el monto a enviar:"
  },
  "inputs": [
    {
      "type": "minecraft:text",
      "key": "player_name",
      "label": "Nombre del Jugador:"
    },
    {
      "type": "minecraft:text",
      "key": "amount",
      "label": "Monto / Cantidad:"
    }
  ],
  "buttons": [
    {
      "label": {
        "text": "✔ Enviar Pago"
      },
      "action": {
        "type": "minecraft:dynamic/run_command",
        "template": "pay $(player_name) $(amount)"
      }
    },
    {
      "label": {
        "text": "⬅ Volver"
      },
      "action": {
        "type": "minecraft:change_page",
        "dialog": "drakescraft:main_menu"
      }
    }
  ]
}
