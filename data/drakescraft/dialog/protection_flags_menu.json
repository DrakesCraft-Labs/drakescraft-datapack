{
  "type": "minecraft:notice",
  "title": {
    "text": "🏳️ Banderas y Reglas de la Protección",
    "bold": true,
    "color": "dark_purple",
    "type": "text"
  },
  "body": [
    {
      "text": "Configura las banderas principales de tu terreno de protección:",
      "type": "text"
    }
  ],
  "inputs": [
    {
      "type": "minecraft:text",
      "key": "greeting_msg",
      "label": "Mensaje de Bienvenida (/ps flag greeting):"
    },
    {
      "type": "minecraft:text",
      "key": "farewell_msg",
      "label": "Mensaje de Despedida (/ps flag farewell):"
    }
  ],
  "buttons": [
    {
      "label": {
        "text": "⚔️ Activar/Desactivar PVP (/ps flag pvp)",
        "type": "text"
      },
      "action": {
        "type": "minecraft:run_command",
        "command": "/ps flag pvp"
      }
    },
    {
      "label": {
        "text": "🧟 Permitir/Bloquear Mobs Hostiles (/ps flag mob-spawning)",
        "type": "text"
      },
      "action": {
        "type": "minecraft:run_command",
        "command": "/ps flag mob-spawning"
      }
    },
    {
      "label": {
        "text": "🚪 Permitir/Bloquear Entrada (/ps flag entry)",
        "type": "text"
      },
      "action": {
        "type": "minecraft:run_command",
        "command": "/ps flag entry"
      }
    },
    {
      "label": {
        "text": "🧰 Permitir/Bloquear Abrir Cofres (/ps flag chest-access)",
        "type": "text"
      },
      "action": {
        "type": "minecraft:run_command",
        "command": "/ps flag chest-access"
      }
    },
    {
      "label": {
        "text": "🔘 Permitir/Bloquear Botones y Puertas (/ps flag use)",
        "type": "text"
      },
      "action": {
        "type": "minecraft:run_command",
        "command": "/ps flag use"
      }
    },
    {
      "label": {
        "text": "🐶 Proteger Animales / Mascotas (/ps flag damage-animals)",
        "type": "text"
      },
      "action": {
        "type": "minecraft:run_command",
        "command": "/ps flag damage-animals"
      }
    },
    {
      "label": {
        "text": "🔥 Activar/Desactivar Fuego Esparcido (/ps flag fire-spread)",
        "type": "text"
      },
      "action": {
        "type": "minecraft:run_command",
        "command": "/ps flag fire-spread"
      }
    },
    {
      "label": {
        "text": "💥 Prevenir Explosiones de TNT (/ps flag tnt)",
        "type": "text"
      },
      "action": {
        "type": "minecraft:run_command",
        "command": "/ps flag tnt"
      }
    },
    {
      "label": {
        "text": "💬 Fijar Mensaje de Bienvenida (/ps flag greeting)",
        "type": "text"
      },
      "action": {
        "type": "minecraft:dynamic/run_command",
        "template": "ps flag greeting $(greeting_msg)"
      }
    },
    {
      "label": {
        "text": "💬 Fijar Mensaje de Despedida (/ps flag farewell)",
        "type": "text"
      },
      "action": {
        "type": "minecraft:dynamic/run_command",
        "template": "ps flag farewell $(farewell_msg)"
      }
    },
    {
      "label": {
        "text": "⬅ Volver a Protecciones",
        "type": "text"
      },
      "action": {
        "type": "minecraft:change_page",
        "dialog": "drakescraft:protection_menu"
      }
    }
  ]
}