{
  "type": "minecraft:notice",
  "title": {
    "text": "🛡️ Protecciones y Terrenos",
    "bold": true,
    "color": "blue",
    "type": "text"
  },
  "body": [
    {
      "text": "Administra tus bloques de protección y permisos de miembros:",
      "type": "text"
    }
  ],
  "inputs": [
    {
      "type": "minecraft:text",
      "key": "member_name",
      "label": "Jugador (para añadir/remover):"
    }
  ],
  "buttons": [
    {
      "label": {
        "text": "📍 Ir a la Protección Actual (/ps home)",
        "type": "text"
      },
      "action": {
        "type": "minecraft:run_command",
        "command": "/ps home"
      }
    },
    {
      "label": {
        "text": "👁️ Mostrar Límites Visibles (/ps view)",
        "type": "text"
      },
      "action": {
        "type": "minecraft:run_command",
        "command": "/ps view"
      }
    },
    {
      "label": {
        "text": "ℹ️ Información de esta Protección (/ps info)",
        "type": "text"
      },
      "action": {
        "type": "minecraft:run_command",
        "command": "/ps info"
      }
    },
    {
      "label": {
        "text": "📜 Lista de Mis Protecciones (/ps list)",
        "type": "text"
      },
      "action": {
        "type": "minecraft:run_command",
        "command": "/ps list"
      }
    },
    {
      "label": {
        "text": "👤 Añadir Miembro Ingresado (/ps add)",
        "type": "text"
      },
      "action": {
        "type": "minecraft:dynamic/run_command",
        "template": "ps add $(member_name)"
      }
    },
    {
      "label": {
        "text": "🚫 Quitar Miembro Ingresado (/ps remove)",
        "type": "text"
      },
      "action": {
        "type": "minecraft:dynamic/run_command",
        "template": "ps remove $(member_name)"
      }
    },
    {
      "label": {
        "text": "🏳️ Configurar Banderas / Flags (/ps flag)",
        "type": "text"
      },
      "action": {
        "type": "minecraft:change_page",
        "dialog": "drakescraft:protection_flags_menu"
      }
    },
    {
      "label": {
        "text": "⬅ Volver al Menú Principal",
        "type": "text"
      },
      "action": {
        "type": "minecraft:change_page",
        "dialog": "drakescraft:main_menu"
      }
    }
  ]
}