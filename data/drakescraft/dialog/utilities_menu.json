{
  "type": "minecraft:notice",
  "title": {
    "text": "⚡ Utilidades y Herramientas",
    "bold": true,
    "color": "gray",
    "type": "text"
  },
  "body": [
    {
      "type": "text",
      "text": "Herramientas de utilidad personal e interacción con jugadores:"
    }
  ],
  "inputs": [
    {
      "key": "msg_player",
      "label": "Jugador Destino (para Mensaje Privado):",
      "type": "minecraft:text"
    },
    {
      "key": "msg_text",
      "label": "Mensaje Privado (/msg):",
      "type": "minecraft:text"
    }
  ],
  "buttons": [
    {
      "label": {
        "text": "💬 Compartir Ítems y Stats en Chat ([i], [inv], [ping])",
        "type": "text"
      },
      "action": {
        "type": "minecraft:change_page",
        "dialog": "drakescraft:chat_placeholders_menu"
      }
    },
    {
      "label": {
        "text": "👁️ Abrir Ender Chest Portátil (/ec)",
        "type": "text"
      },
      "action": {
        "type": "minecraft:run_command",
        "command": "/ec"
      }
    },
    {
      "label": {
        "text": "🛠️ Mesita de Crafteo Portátil (/craft)",
        "type": "text"
      },
      "action": {
        "type": "minecraft:run_command",
        "command": "/craft"
      }
    },
    {
      "label": {
        "text": "🗑️ Abrir Basurero (/trash)",
        "type": "text"
      },
      "action": {
        "type": "minecraft:run_command",
        "command": "/trash"
      }
    },
    {
      "label": {
        "text": "💤 Activar/Desactivar AFK (/afk)",
        "type": "text"
      },
      "action": {
        "type": "minecraft:run_command",
        "command": "/afk"
      }
    },
    {
      "label": {
        "text": "📶 Ver mi Latencia / Ping (/ping)",
        "type": "text"
      },
      "action": {
        "type": "minecraft:run_command",
        "command": "/ping"
      }
    },
    {
      "label": {
        "text": "📊 Ver Estadísticas Personales (/stats)",
        "type": "text"
      },
      "action": {
        "type": "minecraft:run_command",
        "command": "/stats"
      }
    },
    {
      "label": {
        "text": "⏱️ Tiempo Jugado (/playtime)",
        "type": "text"
      },
      "action": {
        "type": "minecraft:run_command",
        "command": "/playtime"
      }
    },
    {
      "label": {
        "text": "✉️ Enviar Mensaje Privado (/msg)",
        "type": "text"
      },
      "action": {
        "type": "minecraft:dynamic/run_command",
        "template": "msg $(msg_player) $(msg_text)"
      }
    },
    {
      "label": {
        "text": "⬅ Volver al Menú Principal",
        "type": "text"
      },
      "action": {
        "type": "minecraft:change_page",
        "dialog": "drakescraft:main_menu"
      }
    }
  ]
}